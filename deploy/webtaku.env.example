# /opt/webtaku/webtaku.env  (chmod 600, owned by ubuntu)
# All values are injected as environment variables into the Spring Boot container.

SERVER_PORT=8089
SERVER_ADDRESS=0.0.0.0
JAVA_OPTS=-Xms512m -Xmx1024m -Dspring.profiles.active=prod

# MySQL (host docker network)
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/webtaku?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=webtaku
SPRING_DATASOURCE_PASSWORD=__CHANGE_ME__

# Redis (host docker network)
SPRING_DATA_REDIS_HOST=host.docker.internal
SPRING_DATA_REDIS_PORT=6379

# JWT
JWT_SECRET=__CHANGE_ME_LONG_RANDOM_STRING__

# JPA — 첫 배포엔 update로 엔티티→테이블 자동 동기화. 안정화되면 validate 또는 none으로.
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# === Stub (인증/연동 없이 일단 부팅만 하기 위한 더미 값) ===

# AWS S3 stub — S3Config가 @Value로 강제 주입이라 더미라도 있어야 부팅됨.
# 실제 업로드 호출 시 런타임 실패 (S3 자격증명 무효).
CLOUD_AWS_CREDENTIALS_ACCESS_KEY=stub
CLOUD_AWS_CREDENTIALS_SECRET_KEY=stub
CLOUD_AWS_REGION_STATIC=ap-northeast-2
CLOUD_AWS_S3_BUCKET=stub-bucket
# CloudFormation/EC2 메타데이터 자동탐지 비활성 (OCI 환경에선 타임아웃 유발)
CLOUD_AWS_STACK_AUTO=false
CLOUD_AWS_REGION_AUTO=false

# Mail (주석 해제 후 값 채우면 활성화. 주석 상태로 두면 Spring이 디폴트 빈만 생성)
#SPRING_MAIL_HOST=smtp.gmail.com
#SPRING_MAIL_PORT=587
#SPRING_MAIL_USERNAME=__CHANGE_ME__
#SPRING_MAIL_PASSWORD=__CHANGE_ME__

# CORS (same-origin behind nginx → 사실상 사용 안 함, fallback)
APP_CORS_ALLOWED_ORIGINS=http://130.162.130.233
