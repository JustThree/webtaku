# /etc/webtaku/webtaku.env  (chmod 600, owner webtaku:webtaku)

JAVA_OPTS=-Xms512m -Xmx1024m -Dspring.profiles.active=prod

SERVER_PORT=8089
SERVER_ADDRESS=127.0.0.1

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/webtaku?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=webtaku
SPRING_DATASOURCE_PASSWORD=__CHANGE_ME__

# Redis
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379

# JWT
JWT_SECRET=__CHANGE_ME_LONG_RANDOM_STRING__

# AWS S3
CLOUD_AWS_CREDENTIALS_ACCESS_KEY=__CHANGE_ME__
CLOUD_AWS_CREDENTIALS_SECRET_KEY=__CHANGE_ME__
CLOUD_AWS_REGION_STATIC=ap-northeast-2
CLOUD_AWS_S3_BUCKET=__CHANGE_ME__

# Mail
SPRING_MAIL_USERNAME=__CHANGE_ME__
SPRING_MAIL_PASSWORD=__CHANGE_ME__

# CORS (same-origin behind nginx → usually no value needed)
APP_CORS_ALLOWED_ORIGINS=http://localhost
